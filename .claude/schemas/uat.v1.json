{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vgflow.dev/schemas/uat.v1.json",
  "title": "VG UAT.md frontmatter (v1)",
  "description": "Validates the YAML frontmatter of a phase UAT.md per SPEC-E section 4.6. Body validation (Login + setup, Per-goal verification, Deviations from acceptance criteria, Sign-off H2 sections; verdict-vs-deviations cross-check) handled by verify-artifact-schema.py.",
  "type": "object",
  "required": ["phase", "verdict", "performed_by", "performed_at", "total_goals_verified", "goals_passed", "goals_failed"],
  "additionalProperties": false,
  "properties": {
    "phase": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)*(-[a-z0-9-]+)?$"
    },
    "verdict": {
      "type": "string",
      "enum": ["ACCEPTED", "REJECTED", "CONDITIONAL"]
    },
    "performed_by": {
      "type": "string",
      "minLength": 1
    },
    "performed_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}"
    },
    "total_goals_verified": {
      "type": "integer",
      "minimum": 0
    },
    "goals_passed": {
      "type": "integer",
      "minimum": 0
    },
    "goals_failed": {
      "type": "integer",
      "minimum": 0
    },
    "platform": {"type": "string"},
    "profile": {"type": "string"},
    "phase_name": {"type": "string"}
  }
}
