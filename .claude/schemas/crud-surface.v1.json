{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vgflow.dev/schemas/crud-surface.v1.json",
  "title": "VG CRUD Surface Contract v1",
  "description": "Resource-level CRUD contract generated by /vg:blueprint and consumed by build/review/test/accept. Uses a base contract plus platform overlays so web, mobile, and backend phases are checked differently.",
  "type": "object",
  "required": ["version", "resources"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "const": "1"
    },
    "generated_from": {
      "type": "array",
      "items": {"type": "string"}
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "operations", "base", "platforms"],
        "additionalProperties": true,
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "domain_owner": {"type": "string"},
          "operations": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["list", "detail", "create", "update", "delete", "bulk"]
            },
            "minItems": 1
          },
          "base": {
            "type": "object",
            "required": ["roles", "business_flow", "security", "abuse", "performance"],
            "additionalProperties": true,
            "properties": {
              "roles": {"type": "array", "items": {"type": "string"}},
              "business_flow": {"type": "object"},
              "security": {"type": "object"},
              "abuse": {"type": "object"},
              "performance": {"type": "object"},
              "accessibility": {"type": "object"},
              "delete_policy": {"type": "object"}
            }
          },
          "platforms": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "web": {"type": "object"},
              "mobile": {"type": "object"},
              "backend": {"type": "object"},
              "desktop": {"type": "object"},
              "cli": {"type": "object"}
            }
          }
        }
      }
    }
  }
}
