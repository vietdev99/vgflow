{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vgflow.dev/schemas/summary.v1.json",
  "title": "VG SUMMARY.md frontmatter (v1)",
  "description": "Validates the YAML frontmatter of a phase SUMMARY.md per SPEC-E section 4.5. Body validation (Tasks shipped + Files touched + Goal coverage + Deviations + Next steps H2 sections) handled by verify-artifact-schema.py.",
  "type": "object",
  "required": ["phase", "status", "total_tasks", "tasks_completed", "total_waves", "generated_at", "final_commit"],
  "additionalProperties": false,
  "properties": {
    "phase": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)*(-[a-z0-9-]+)?$"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "partial"]
    },
    "total_tasks": {
      "type": "integer",
      "minimum": 0
    },
    "tasks_completed": {
      "type": "integer",
      "minimum": 0
    },
    "total_waves": {
      "type": "integer",
      "minimum": 0
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}"
    },
    "final_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$",
      "description": "Short or full git SHA"
    },
    "platform": {"type": "string"},
    "profile": {"type": "string"},
    "phase_name": {"type": "string"}
  }
}
